#include <iostream>
using namespace std;

class Student {
private:
    int roll_number;
    string name;
    float marks[5];

public:
    Student() {
        roll_number = 0;
        name = "Unknown";
        for(int i = 0; i < 5; i++) marks[i] = 0;
    }

    Student(int r, string n, float m[]) {
        roll_number = r;
        name = n;
        for(int i = 0; i < 5; i++) marks[i] = m[i];
    }

    Student(int r) {
        roll_number = r;
        name = "Not Assigned";
        for(int i = 0; i < 5; i++) marks[i] = 0;
    }

    ~Student() {
        cout << "Record destroyed\n";
    }

    void addStudent() {
        cin >> roll_number >> name;
        for(int i = 0; i < 5; i++) cin >> marks[i];
    }

    void displayStudent() {
        cout << roll_number << " " << name << endl;
        for(int i = 0; i < 5; i++) cout << marks[i] << " ";
        cout << "\nAvg: " << calculateAverage() << endl;
    }

    float calculateAverage() {
        float sum = 0;
        for(int i = 0; i < 5; i++) sum += marks[i];
        return sum / 5;
    }
};

class GraduateStudent : public Student {
private:
    string topic;

public:
    void setTopic(string t) {
        topic = t;
    }

    void display() {
        displayStudent();
        cout << topic << endl;
    }
};

int main() {
    float m[5] = {80,85,90,75,88};

    Student s1(1,"Rahul",m);
    s1.displayStudent();

    Student s2;
    s2.addStudent();
    s2.displayStudent();

    GraduateStudent g;
    g.addStudent();
    g.setTopic("AI");
    g.display();

    return 0;
}
